                    "Description": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Biomass-Description\", \"Right click to collect bulk-order of pre-packaged excess biomass, taken directly from UDA stockpiles \\\"less than honorably\\\" and sold to prospectors loyal to Norex.\")",
                    "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Biomass-FlavorText\", \"The contents of this package cannot be returned to the Orbital Station. Comes in a reusable crate. No refunds.\")",
