                    "Icon": "/Game/Assets/2DArt/UI/Items/Item_Icons/Deployables/ITEM_Meta_Crate_Printed.ITEM_Meta_Crate_Printed",
                    "Description": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_MiniBase_Deluxe-Description\", \"Right click to collect a premium prefabricated concrete housing kit, including the following assets: 20 concrete walls, 20 concrete floors, 20 concrete beams, 2 Concrete doors, 1 Concrete furnace, 1 Composter, 1 Biofuel Oxite Dissolver, 1 Electrical Appliance Charging Device, 2 Advanced battery, 1 Large Biofuel power generator, 1 Electric water pump, 1 Fabrication Bench, 1 Forge, 1 Hydrazine Heater, 1 Hydrazine Cooker, 1 Advanced Orbital Exchange Interface, 1 Prefabricated Cot, 1 Biofuel Canister, 1 Hydrazine Canister, 50 units of coal, and 1 set of assorted connection tools, all pre-packaged and sold at a discount rate.\")",
                    "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_MiniBase_Deluxe-FlavorText\", \"The contents of this package cannot be returned to the Orbital Station. Comes in a reusable crate. No refunds.\")",
                    "Weight": 25000
                },
                {
