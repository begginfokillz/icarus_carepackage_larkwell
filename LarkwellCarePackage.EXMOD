                },
                {
                    "Name": "Item_Meta_Carepackage_Uranium_Raw",
                    "DisplayName": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Uranium_Raw-DisplayName\", \"Norex \\\"Nuke It From Orbit\\\" Care Package\")",
                    "Icon": "/Game/Assets/2DArt/UI/Items/Item_Icons/Deployables/ITEM_Meta_Crate_Printed.ITEM_Meta_Crate_Printed",
                    "Description": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Uranium_Raw-Description\", \"Right click to collect a small batch of unprocessed nuclear material, taken directly from UDA stockpiles \\\"less than honorably\\\" and re-sold to prospectors loyal to Norex for use in any region on Icarus. Norex is not responsible for radiation based ailments you might encounter once the package is unsealed.\")",
                    "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Uranium_Raw-FlavorText\", \"The contents of this package cannot be returned to the Orbital Station. Comes in a reusable crate. No refunds.\")",
                    "Weight": 1000
                },
                {
                    "Name": "Item_Meta_Carepackage_PetCare",
                    "DisplayName": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_PetCare-DisplayName\", \"Agrizero \\\"EZ-TAME\\\" Care Package\")",
                    "Icon": "/Game/Assets/2DArt/UI/Items/Item_Icons/Deployables/ITEM_Meta_Crate_Printed.ITEM_Meta_Crate_Printed",
                    "Description": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_PetCare-Description\", \"Right click to collect bulk-order of pre-packaged pet food and basic supplies, all sold at a discount rate. This package is only sold to select Agrizero Brand Ambassadors.\")",
                    "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_PetCare-FlavorText\", \"The contents of this package cannot be returned to the Orbital Station. Comes in a reusable crate. No refunds.\")",
                    "Weight": 1000
                },
                {
                    "Name": "Item_Meta_Carepackage_Excavation",
                    "DisplayName": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Excavation-DisplayName\", \"Inaris \\\"Digger, Please!\\\" Care Package\")",
                    "Icon": "/Game/Assets/2DArt/UI/Items/Item_Icons/Deployables/ITEM_Meta_Crate_Printed.ITEM_Meta_Crate_Printed",
                    "Description": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Excavation-Description\", \"Right click to collect a single electronic excavation device, a portable generator, a wiring tool, and a pre-filled biofuel canister, all pre-packaged and sold at a discount rate.\")",
                    "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Excavation-FlavorText\", \"The contents of this package cannot be returned to the Orbital Station. Comes in a reusable crate. No refunds.\")",
                    "Weight": 1000
                },
                {
                    "Name": "Item_Meta_Carepackage_Excavation_Drilling",
                    "DisplayName": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Excavation_Drilling-DisplayName\", \"Inaris \\\"Drill Deep!\\\" Care Package\")",
                    "Icon": "/Game/Assets/2DArt/UI/Items/Item_Icons/Deployables/ITEM_Meta_Crate_Printed.ITEM_Meta_Crate_Printed",
                    "Description": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Excavation_Drilling-Description\", \"Right click to collect a premium handheld deep deposit location scanner system, an electric deep drilling device, a pair of portable solar panels, and a wiring tool, all pre-packaged and sold at a discount rate.\")",
                    "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_Excavation_Drilling-FlavorText\", \"The contents of this package cannot be returned to the Orbital Station. Comes in a reusable crate. No refunds.\")",
                    "Weight": 1000
                },
                {
                    "Name": "Item_Meta_Carepackage_MiniBase",
                    "DisplayName": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_MiniBase-DisplayName\", \"CHAC \\\"Cubicle\\\" Care Package\")",
                    "Icon": "/Game/Assets/2DArt/UI/Items/Item_Icons/Deployables/ITEM_Meta_Crate_Printed.ITEM_Meta_Crate_Printed",
                    "Description": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_MiniBase-Description\", \"Right click to collect a premium prefabricated Aluminium housing kit, including the following assets: 20 Aluminium walls, 20 Aluminium floors, 20 Aluminium beams, 2 Aluminium doors, 1 Concrete furnace, 1 Composter, 1 Biofuel Oxite Dissolver, 1 Electrical Appliance Charging Device, 1 Basic battery, 2 Solar power kits, 1 Electric water pump, 1 Fabrication Bench, 1 Anvil, 1 Hydrazine Heater, 1 Hydrazine Cooker, 1 Basic Orbital Exchange Interface, 1 Prefabricated Cot, 1 Biofuel Canister, 1 Hydrazine Canister, 50 units of coal, and 1 set of assorted connection tools, all pre-packaged and sold at a discount rate.\")",
                    "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_Meta_Carepackage_MiniBase-FlavorText\", \"The contents of this package cannot be returned to the Orbital Station. Comes in a reusable crate. No refunds.\")",
                    "Weight": 25000
                },
                {
                    "Name": "Item_Meta_Carepackage_MiniBase_Deluxe",
